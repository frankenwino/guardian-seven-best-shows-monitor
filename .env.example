# Discord Webhook Configuration (REQUIRED)
# Get your webhook URL from Discord:
# 1. Go to your Discord server
# 2. Right-click on the channel where you want notifications
# 3. Select "Edit Channel" > "Integrations" > "Webhooks"
# 4. Create a new webhook and copy the URL

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Example:
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/123456789012345678/abcdefghijklmnopqrstuvwxyz1234567890

# Discord Bot Token (required for bulk-deleting channel messages)
# Found in Discord Developer Portal → Your App → Bot → Reset Token
DISCORD_BOT_TOKEN=your_bot_token_here
